generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model permission {
  PermissionID   Int              @id @default(autoincrement())
  PermissionCode String           @unique(map: "PermissionCode") @db.VarChar(100)
  Description    String?          @db.VarChar(250)
  rolepermission rolepermission[]
}

model role {
  RoleID         Int              @id @default(autoincrement())
  RoleName       String           @db.VarChar(100)
  RoleCode       String           @unique(map: "RoleCode") @db.VarChar(50)
  Description    String?          @db.VarChar(250)
  IsActive       Boolean?         @default(dbgenerated("b'1'")) @db.Bit(1)
  rolepermission rolepermission[]
  userrole       userrole[]
}

model rolepermission {
  RolePermissionID Int        @id @default(autoincrement())
  RoleID           Int
  PermissionID     Int
  permission       permission @relation(fields: [PermissionID], references: [PermissionID], onDelete: NoAction, onUpdate: NoAction, map: "FK_RP_Permission")
  role             role       @relation(fields: [RoleID], references: [RoleID], onDelete: NoAction, onUpdate: NoAction, map: "FK_RP_Role")

  @@unique([RoleID, PermissionID], map: "RoleID")
  @@index([PermissionID], map: "FK_RP_Permission")
}

model servicedept {
  ServiceDeptID         Int                  @id @default(autoincrement())
  ServiceDeptName       String               @db.VarChar(250)
  CampusID              Int
  Description           String?              @db.VarChar(250)
  CCEmailToCSV          String?              @db.VarChar(250)
  IsRequestTitleDisable Boolean?             @db.Bit(1)
  UserID                Int
  Created               DateTime             @db.DateTime(0)
  Modified              DateTime             @db.DateTime(0)
  IsActive              Boolean?             @default(dbgenerated("b'1'")) @db.Bit(1)
  ManagerStaffID        Int?
  staff                 staff?               @relation(fields: [ManagerStaffID], references: [StaffID], onDelete: NoAction, onUpdate: NoAction, map: "FK_ServiceDept_Manager")
  user                  user                 @relation(fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction, map: "FK_ServiceDept_User")
  servicedeptperson     servicedeptperson[]
  servicerequesttype    servicerequesttype[]

  @@index([UserID], map: "FK_ServiceDept_User")
  @@index([ManagerStaffID], map: "FK_ServiceDept_Manager")
}

model servicedeptperson {
  ServiceDeptPersonID Int         @id @default(autoincrement())
  ServiceDeptID       Int
  StaffID             Int
  FromDate            DateTime    @db.DateTime(0)
  ToDate              DateTime?   @db.DateTime(0)
  Description         String?     @db.VarChar(250)
  IsHODStaff          Boolean?    @db.Bit(1)
  UserID              Int
  Created             DateTime    @db.DateTime(0)
  Modified            DateTime    @db.DateTime(0)
  servicedept         servicedept @relation(fields: [ServiceDeptID], references: [ServiceDeptID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SDP_Dept")
  staff               staff       @relation(fields: [StaffID], references: [StaffID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SDP_Staff")
  user                user        @relation(fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SDP_User")

  @@index([ServiceDeptID], map: "FK_SDP_Dept")
  @@index([StaffID], map: "FK_SDP_Staff")
  @@index([UserID], map: "FK_SDP_User")
}

model servicerequest {
  ServiceRequestID                                       Int                               @id @default(autoincrement())
  ServiceRequestNo                                       String                            @db.VarChar(500)
  ServiceRequestDateTime                                 DateTime                          @db.DateTime(0)
  ServiceRequestTypeID                                   Int
  ServiceRequestTitle                                    String                            @db.VarChar(250)
  ServiceRequestDescription                              String                            @db.VarChar(2000)
  ServiceRequestStatusID                                 Int
  RequestedByStaffID                                     Int?
  AssignedToStaffID                                      Int?
  AssignedByUserID                                       Int?
  ServiceRequestStatusDateTime                           DateTime?                         @db.DateTime(0)
  ServiceRequestStatusByUserID                           Int?
  ServiceRequestStatusDescription                        String?                           @db.VarChar(500)
  PriorityLevel                                          String?                           @db.VarChar(50)
  ResourceID                                             Int?
  StudentID                                              Int?
  AttachmentPath                                         String?                           @db.VarChar(250)
  AttachmentPath2                                        String?                           @db.VarChar(250)
  AttachmentPath3                                        String?                           @db.VarChar(250)
  AttachmentPath4                                        String?                           @db.VarChar(250)
  AttachmentPath5                                        String?                           @db.VarChar(250)
  AttachmentFileOriginalName                             String?                           @db.VarChar(250)
  UserID                                                 Int
  Created                                                DateTime                          @db.DateTime(0)
  Modified                                               DateTime                          @db.DateTime(0)
  user_servicerequest_AssignedByUserIDTouser             user?                             @relation("servicerequest_AssignedByUserIDTouser", fields: [AssignedByUserID], references: [UserID], onUpdate: NoAction, map: "FK_SR_AssignedByUser")
  staff_servicerequest_AssignedToStaffIDTostaff          staff?                            @relation("servicerequest_AssignedToStaffIDTostaff", fields: [AssignedToStaffID], references: [StaffID], onUpdate: NoAction, map: "FK_SR_AssignedStaff")
  staff_servicerequest_RequestedByStaffIDTostaff         staff?                            @relation("servicerequest_RequestedByStaffIDTostaff", fields: [RequestedByStaffID], references: [StaffID], onUpdate: NoAction, map: "FK_SR_RequestedStaff")
  servicerequeststatus                                   servicerequeststatus              @relation(fields: [ServiceRequestStatusID], references: [ServiceRequestStatusID], onDelete: NoAction, onUpdate: NoAction, map: "FK_SR_Status")
  user_servicerequest_ServiceRequestStatusByUserIDTouser user?                             @relation("servicerequest_ServiceRequestStatusByUserIDTouser", fields: [ServiceRequestStatusByUserID], references: [UserID], onUpdate: NoAction, map: "FK_SR_StatusByUser")
  servicerequesttype                                     servicerequesttype                @relation(fields: [ServiceRequestTypeID], references: [ServiceRequestTypeID], onDelete: NoAction, onUpdate: NoAction, map: "FK_SR_Type")
  user_servicerequest_UserIDTouser                       user                              @relation("servicerequest_UserIDTouser", fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SR_User")
  servicerequestassignmenthistory                        servicerequestassignmenthistory[]
  servicerequestreply                                    servicerequestreply[]

  @@index([AssignedByUserID], map: "FK_SR_AssignedByUser")
  @@index([AssignedToStaffID], map: "FK_SR_AssignedStaff")
  @@index([RequestedByStaffID], map: "FK_SR_RequestedStaff")
  @@index([ServiceRequestStatusID], map: "FK_SR_Status")
  @@index([ServiceRequestStatusByUserID], map: "FK_SR_StatusByUser")
  @@index([ServiceRequestTypeID], map: "FK_SR_Type")
  @@index([UserID], map: "FK_SR_User")
}

model servicerequestreply {
  ServiceRequestReplyID                                       Int                  @id @default(autoincrement())
  ServiceRequestID                                            Int
  StaffID                                                     Int?
  ServiceRequestReplyDateTime                                 DateTime             @db.DateTime(0)
  ServiceRequestReplyDescription                              String               @db.VarChar(250)
  ServiceRequestStatusID                                      Int
  ServiceRequestStatusDateTime                                DateTime             @db.DateTime(0)
  ServiceRequestStatusByUserID                                Int
  ServiceRequestStatusDescription                             String?              @db.VarChar(250)
  AttachmentPath                                              String?              @db.VarChar(250)
  AttachmentFileOriginalName                                  String?              @db.VarChar(250)
  UserID                                                      Int
  Created                                                     DateTime             @db.DateTime(0)
  Modified                                                    DateTime             @db.DateTime(0)
  servicerequest                                              servicerequest       @relation(fields: [ServiceRequestID], references: [ServiceRequestID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRR_Request")
  staff                                                       staff?               @relation(fields: [StaffID], references: [StaffID], onUpdate: NoAction, map: "FK_SRR_Staff")
  servicerequeststatus                                        servicerequeststatus @relation(fields: [ServiceRequestStatusID], references: [ServiceRequestStatusID], onDelete: NoAction, onUpdate: NoAction, map: "FK_SRR_Status")
  user_servicerequestreply_ServiceRequestStatusByUserIDTouser user                 @relation("servicerequestreply_ServiceRequestStatusByUserIDTouser", fields: [ServiceRequestStatusByUserID], references: [UserID], onDelete: NoAction, onUpdate: NoAction, map: "FK_SRR_StatusByUser")
  user_servicerequestreply_UserIDTouser                       user                 @relation("servicerequestreply_UserIDTouser", fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRR_User")

  @@index([ServiceRequestID], map: "FK_SRR_Request")
  @@index([StaffID], map: "FK_SRR_Staff")
  @@index([ServiceRequestStatusID], map: "FK_SRR_Status")
  @@index([ServiceRequestStatusByUserID], map: "FK_SRR_StatusByUser")
  @@index([UserID], map: "FK_SRR_User")
}

model servicerequeststatus {
  ServiceRequestStatusID         Int                   @id @default(autoincrement())
  ServiceRequestStatusName       String                @db.VarChar(250)
  ServiceRequestStatusSystemName String                @db.VarChar(100)
  Sequence                       Decimal?              @db.Decimal(10, 2)
  Description                    String?               @db.VarChar(250)
  ServiceRequestStatusCssClass   String?               @db.VarChar(250)
  IsOpen                         Boolean?              @db.Bit(1)
  IsNoFurtherActionRequired      Boolean?              @db.Bit(1)
  IsAllowedForTechnician         Boolean?              @db.Bit(1)
  UserID                         Int
  Created                        DateTime              @db.DateTime(0)
  Modified                       DateTime              @db.DateTime(0)
  servicerequest                 servicerequest[]
  servicerequestreply            servicerequestreply[]
  user                           user                  @relation(fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRS_User")

  @@index([UserID], map: "FK_SRS_User")
}

model servicerequesttype {
  ServiceRequestTypeID         Int                            @id @default(autoincrement())
  ServiceTypeID                Int
  ServiceDeptID                Int
  ServiceRequestTypeName       String                         @db.VarChar(250)
  Description                  String?                        @db.VarChar(250)
  Sequence                     Decimal?                       @db.Decimal(10, 2)
  RequestTotal                 Int                            @default(0)
  RequestPending               Int                            @default(0)
  RequestClosed                Int                            @default(0)
  RequestCancelled             Int                            @default(0)
  IsVisibleResource            Boolean?                       @db.Bit(1)
  DefaultPriorityLevel         String?                        @db.VarChar(50)
  ReminderDaysAfterAssignment  Int?
  IsMandatoryResource          Boolean?                       @db.Bit(1)
  UserID                       Int
  Created                      DateTime                       @db.DateTime(0)
  Modified                     DateTime                       @db.DateTime(0)
  servicerequest               servicerequest[]
  servicedept                  servicedept                    @relation(fields: [ServiceDeptID], references: [ServiceDeptID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRT_ServiceDept")
  servicetype                  servicetype                    @relation(fields: [ServiceTypeID], references: [ServiceTypeID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRT_ServiceType")
  user                         user                           @relation(fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRT_User")
  servicerequesttypewiseperson servicerequesttypewiseperson[]

  @@index([ServiceDeptID], map: "FK_SRT_ServiceDept")
  @@index([ServiceTypeID], map: "FK_SRT_ServiceType")
  @@index([UserID], map: "FK_SRT_User")
}

model servicerequesttypewiseperson {
  ServiceRequestTypeWisePersonID Int                @id @default(autoincrement())
  ServiceRequestTypeID           Int
  StaffID                        Int
  FromDate                       DateTime           @db.DateTime(0)
  ToDate                         DateTime?          @db.DateTime(0)
  Description                    String?            @db.VarChar(250)
  UserID                         Int
  Created                        DateTime           @db.DateTime(0)
  Modified                       DateTime           @db.DateTime(0)
  staff                          staff              @relation(fields: [StaffID], references: [StaffID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRTWP_Staff")
  servicerequesttype             servicerequesttype @relation(fields: [ServiceRequestTypeID], references: [ServiceRequestTypeID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRTWP_Type")
  user                           user               @relation(fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRTWP_User")

  @@index([StaffID], map: "FK_SRTWP_Staff")
  @@index([ServiceRequestTypeID], map: "FK_SRTWP_Type")
  @@index([UserID], map: "FK_SRTWP_User")
}

model servicetype {
  ServiceTypeID      Int                  @id @default(autoincrement())
  ServiceTypeName    String               @db.VarChar(250)
  Description        String?              @db.VarChar(250)
  Sequence           Decimal?             @db.Decimal(10, 2)
  IsForStaff         Boolean?             @db.Bit(1)
  IsForStudent       Boolean?             @db.Bit(1)
  UserID             Int
  Created            DateTime             @db.DateTime(0)
  Modified           DateTime             @db.DateTime(0)
  servicerequesttype servicerequesttype[]
  user               user                 @relation(fields: [UserID], references: [UserID], onDelete: Cascade, onUpdate: NoAction, map: "FK_ServiceType_User")

  @@index([UserID], map: "FK_ServiceType_User")
}

model staff {
  StaffID                                                 Int                               @id @default(autoincrement())
  UserID                                                  Int
  StaffCode                                               String?                           @unique(map: "StaffCode") @db.VarChar(50)
  Department                                              String?                           @db.VarChar(150)
  Designation                                             String?                           @db.VarChar(150)
  IsActive                                                Boolean?                          @default(dbgenerated("b'1'")) @db.Bit(1)
  Created                                                 DateTime                          @db.DateTime(0)
  Modified                                                DateTime                          @db.DateTime(0)
  servicedept                                             servicedept[]
  servicedeptperson                                       servicedeptperson[]
  servicerequest_servicerequest_AssignedToStaffIDTostaff  servicerequest[]                  @relation("servicerequest_AssignedToStaffIDTostaff")
  servicerequest_servicerequest_RequestedByStaffIDTostaff servicerequest[]                  @relation("servicerequest_RequestedByStaffIDTostaff")
  servicerequestassignmenthistory                         servicerequestassignmenthistory[]
  servicerequestreply                                     servicerequestreply[]
  servicerequesttypewiseperson                            servicerequesttypewiseperson[]
  user                                                    user                              @relation(fields: [UserID], references: [UserID], onDelete: NoAction, onUpdate: NoAction, map: "FK_Staff_User")

  @@index([UserID], map: "FK_Staff_User")
}

model user {
  UserID                                                                     Int                               @id @default(autoincrement())
  Username                                                                   String                            @unique(map: "Username") @db.VarChar(100)
  PasswordHash                                                               String                            @db.VarChar(255)
  Email                                                                      String                            @unique(map: "Email") @db.VarChar(150)
  MobileNo                                                                   String?                           @db.VarChar(20)
  IsActive                                                                   Boolean?                          @default(dbgenerated("b'1'")) @db.Bit(1)
  Created                                                                    DateTime                          @db.DateTime(0)
  Modified                                                                   DateTime                          @db.DateTime(0)
  servicedept                                                                servicedept[]
  servicedeptperson                                                          servicedeptperson[]
  servicerequest_servicerequest_AssignedByUserIDTouser                       servicerequest[]                  @relation("servicerequest_AssignedByUserIDTouser")
  servicerequest_servicerequest_ServiceRequestStatusByUserIDTouser           servicerequest[]                  @relation("servicerequest_ServiceRequestStatusByUserIDTouser")
  servicerequest_servicerequest_UserIDTouser                                 servicerequest[]                  @relation("servicerequest_UserIDTouser")
  servicerequestassignmenthistory                                            servicerequestassignmenthistory[]
  servicerequestreply_servicerequestreply_ServiceRequestStatusByUserIDTouser servicerequestreply[]             @relation("servicerequestreply_ServiceRequestStatusByUserIDTouser")
  servicerequestreply_servicerequestreply_UserIDTouser                       servicerequestreply[]             @relation("servicerequestreply_UserIDTouser")
  servicerequeststatus                                                       servicerequeststatus[]
  servicerequesttype                                                         servicerequesttype[]
  servicerequesttypewiseperson                                               servicerequesttypewiseperson[]
  servicetype                                                                servicetype[]
  staff                                                                      staff[]
  userroles                                                                  userrole[]
}

model userrole {
  UserRoleID Int  @id @default(autoincrement())
  UserID     Int
  RoleID     Int
  role       role @relation(fields: [RoleID], references: [RoleID], onDelete: NoAction, onUpdate: NoAction, map: "FK_UR_Role")
  user       user @relation(fields: [UserID], references: [UserID])

  @@unique([UserID, RoleID], map: "UserID")
  @@index([RoleID], map: "FK_UR_Role")
}

model servicerequestassignmenthistory {
  ServiceRequestAssignmentHistoryID Int            @id @default(autoincrement())
  ServiceRequestID                  Int
  AssignedToStaffID                 Int
  AssignedByUserID                  Int
  AssignedDateTime                  DateTime       @db.DateTime(0)
  Description                       String?        @db.VarChar(250)
  servicerequest                    servicerequest @relation(fields: [ServiceRequestID], references: [ServiceRequestID], onDelete: Cascade, onUpdate: NoAction, map: "FK_SRAH_Request")
  staff                             staff          @relation(fields: [AssignedToStaffID], references: [StaffID], onDelete: NoAction, onUpdate: NoAction, map: "FK_SRAH_Staff")
  user                              user           @relation(fields: [AssignedByUserID], references: [UserID], onDelete: NoAction, onUpdate: NoAction, map: "FK_SRAH_User")

  @@index([ServiceRequestID], map: "FK_SRAH_Request")
  @@index([AssignedToStaffID], map: "FK_SRAH_Staff")
  @@index([AssignedByUserID], map: "FK_SRAH_User")
}
